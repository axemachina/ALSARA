# === REQUIRED ===
ANTHROPIC_API_KEY=sk-ant-...          # Claude API key

# === MODEL CONFIGURATION ===
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
MAX_RESPONSE_TOKENS=16384

# === AACT DATABASE (free public access — credentials required) ===
# Register at https://aact.ctti-clinicaltrials.org/users/sign_up
AACT_HOST=aact-db.ctti-clinicaltrials.org
AACT_PORT=5432
AACT_DB=aact
AACT_USER=your_username
AACT_PASSWORD=your_password

# === OPTIONAL: PubMed ===
# Providing an email increases rate limits from 3 to 10 requests/second
PUBMED_EMAIL=your_email@example.com

# === FEATURE FLAGS ===
ENABLE_RAG=true                       # Enable semantic search (needs ~2GB RAM for embeddings)
ENABLE_BIORXIV=true                   # Enable bioRxiv preprint search

# === USER CONTEXT ===
# Country/region the primary user lives in. The agent biases trial suggestions
# toward this location and frames answers for a patient (not a clinician).
USER_LOCATION=France

# === APP AUTHENTICATION (set both to enable login screen) ===
APP_USERNAME=alsara
APP_PASSWORD=choose_a_strong_password

# === PERSISTENT RAG STORAGE (HF Spaces) ===
# Enable HF Spaces Persistent Storage add-on in Space Settings, then:
# CHROMA_DB_PATH=/data/chroma_db
# Leave unset for local dev (defaults to ./chroma_db)
CHROMA_DB_PATH=

# === DATASET BACKUP (optional but recommended) ===
# Periodic snapshot of chroma_db to a private HF Dataset repo.
# Enables cross-restart durability even without Persistent Storage,
# and makes the data portable back to local dev.
# Token needs WRITE access to the Dataset repo.
CHROMA_SYNC_REPO=         # e.g. axegameon/alsara-chroma
HF_TOKEN=                 # hf_... with WRITE to the Dataset
CHROMA_SYNC_BATCH_SIZE=5  # upload every N new indexed papers

# === OPTIONAL: Fallback LLM ===
# USE_FALLBACK_LLM=true
# SAMBANOVA_API_KEY=your_key
